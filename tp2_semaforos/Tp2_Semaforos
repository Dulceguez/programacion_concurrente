1.  Queue sistema_operativo(recursos, 5); // 5 recursos
    int recursos = 5;

    sem mutex_recursos = 1;
    sem mutex_cola = 1;

    Process Proceso[id: 0..P-1] {
        Recurso r;

        while(true) {
            P(mutex_recursos);
            if (recursos > 0) {
                recursos--;
                V(mutex_recursos);

                P(mutex_recursos);
                pop(sistema_operativo, r);
                V(mutex_recursos);

                -- uso recurso

                P(mutex_cola);
                push(sistema_operativo, r);
                V(mutex_cola);

                P(mutex_recursos);
                recursos++;
                V(mutex_recursos);

            } else V(mutex_recursos);   
        }
    }

