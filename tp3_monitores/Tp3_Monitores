            int cantidadConsultas = 5;
            cond hayLugar;

            Procedure leer() {
                if (cantidadConsultas == 0) {
                    wait(hayLugar); 
                }

                cantidadConsultas --;
            }
            
            Procedure salir() {
                
                cantidadConsultas++;
                signal(hayLugar);
        }

